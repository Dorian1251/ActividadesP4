// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id            Int          @id @default(autoincrement())
  nombre        String
  email         String       @unique
  password      String
  rol           String
  sesiones      Sesion[]
  asistencias   Asistencia[]
  gruposCreados Grupo[]      @relation("OrganizadorGrupo")
  recursos      Recurso[]
  grupos        Grupo[]      @relation("IntegrantesGrupo")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([rol])
}

model Materia {
  id        Int       @id @default(autoincrement())
  nombre    String
  codigo    String    @unique
  docente   String?
  semestre  String?
  sesiones  Sesion[]
  recursos  Recurso[]
  grupos    Grupo[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([semestre])
}

model Grupo {
  id            Int       @id @default(autoincrement())
  nombre        String
  descripcion   String
  materiaId     Int
  organizadorId Int
  materia       Materia   @relation(fields: [materiaId], references: [id])
  organizador   Usuario   @relation("OrganizadorGrupo", fields: [organizadorId], references: [id])
  integrantes   Usuario[] @relation("IntegrantesGrupo")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([materiaId])
  @@index([organizadorId])
}

model Sesion {
  id               Int          @id @default(autoincrement())
  titulo           String
  descripcion      String?
  fecha            String
  hora             String
  modalidad        String
  codigoAsistencia String?      @unique @default(uuid())
  usuarioId        Int
  materiaId        Int
  usuario          Usuario      @relation(fields: [usuarioId], references: [id])
  materia          Materia      @relation(fields: [materiaId], references: [id])
  asistencias      Asistencia[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([fecha])
  @@index([materiaId])
  @@index([usuarioId])
}

model Asistencia {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  sesionId  Int
  fechaHora DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  sesion    Sesion   @relation(fields: [sesionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([usuarioId, sesionId])
  @@index([sesionId])
  @@index([usuarioId])
}

model Recurso {
  id          Int      @id @default(autoincrement())
  titulo      String
  tipo        String
  url         String
  descripcion String?
  usuarioId   Int
  materiaId   Int
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  materia     Materia  @relation(fields: [materiaId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tipo])
  @@index([materiaId])
  @@index([usuarioId])
}
